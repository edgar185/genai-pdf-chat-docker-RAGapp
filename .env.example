#*****************************************************************
# LLM and Embedding Model
#*****************************************************************
# Options: tinyllama | llama2 | neural-chat
LLM=tinyllama
EMBEDDING_MODEL=sentence_transformer

#*****************************************************************
# Neo4j  (points at the local containerized Neo4j, not a managed instance)
#*****************************************************************
NEO4J_URI=neo4j://database:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change_me

#*****************************************************************
# Ollama
#*****************************************************************
OLLAMA_BASE_URL=http://ollama:11434

#*****************************************************************
# OpenAI  (only required if using an OpenAI LLM or embedding model)
#*****************************************************************
# OPENAI_API_KEY=sk-...
